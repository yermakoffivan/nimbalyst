{
  "id": "com.nimbalyst.math",
  "name": "Math",
  "version": "1.0.0",
  "description": "Render LaTeX-style math in the agent transcript and Lexical editor via KaTeX.",
  "author": "Nimbalyst",
  "main": "dist/index.js",
  "styles": "dist/index.css",
  "apiVersion": "1.0.0",
  "defaultEnabled": true,
  "permissions": {
    "filesystem": false,
    "ai": false
  },
  "contributions": {
    "hostComponents": ["TranscriptMathHost"],
    "transformers": ["BLOCK_MATH_TRANSFORMER", "INLINE_MATH_TRANSFORMER"],
    "lexicalExtensions": ["MathLexicalExtension"],
    "slashCommands": [
      {
        "id": "com.nimbalyst.math.inline",
        "title": "Math (inline)",
        "description": "Insert an inline LaTeX math formula",
        "icon": "functions",
        "keywords": ["math", "latex", "katex", "equation", "formula", "inline"],
        "handler": "insertInlineMath"
      },
      {
        "id": "com.nimbalyst.math.block",
        "title": "Math (block)",
        "description": "Insert a block LaTeX math formula",
        "icon": "calculate",
        "keywords": ["math", "latex", "katex", "equation", "formula", "block"],
        "handler": "insertBlockMath"
      }
    ]
  }
}
