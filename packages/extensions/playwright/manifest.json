{
  "id": "com.nimbalyst.playwright",
  "name": "Playwright",
  "version": "0.1.2",
  "description": "Test runner, trace viewer, and screenshot automation for Playwright",
  "author": "Nimbalyst",
  "main": "dist/index.js",
  "styles": "dist/index.css",
  "apiVersion": "1.0.0",
  "requiredReleaseChannel": "alpha",
  "permissions": {
    "filesystem": true,
    "ai": true
  },
  "contributions": {
    "panels": [
      {
        "id": "test-explorer",
        "title": "Playwright Tests",
        "icon": "science",
        "placement": "fullscreen",
        "aiSupported": true,
        "order": 50
      }
    ],
    "aiTools": [
      "playwright.list_tests",
      "playwright.run_test",
      "playwright.get_failures",
      "playwright.get_flaky_tests",
      "playwright.get_history"
    ],
    "configuration": {
      "title": "Playwright",
      "properties": {
        "configPath": {
          "type": "string",
          "description": "Path to playwright.config.ts (relative to workspace root)",
          "default": "playwright.config.ts",
          "scope": "workspace",
          "order": 1
        },
        "serialExecution": {
          "type": "boolean",
          "description": "Force serial test execution (required for Electron/database-locked apps)",
          "default": false,
          "scope": "workspace",
          "order": 2
        }
      }
    },
    "fileIcons": {
      "*.spec.ts": "science",
      "*.spec.js": "science"
    }
  }
}
